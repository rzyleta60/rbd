CREATE OR REPLACE PROCEDURE raport_umow_szczecin IS
BEGIN
  FOR r IN (
    SELECT u.umowa_id, k_f.imie, k_f.nazwisko, r_f.nazwa AS nazwa_kursu, r_f.cena, u.miasto
    FROM umowy u
    JOIN kursanciFilia k_f ON u.kursant_id = k_f.kursant_id
    JOIN kursyFilia k_m ON u.kurs_id = k_m.kurs_id
    JOIN rodzajeFilia r_f ON k_m.rodzaj_id = r_f.rodzaj_id
    WHERE u.miasto = 'SZCZECIN'
  ) LOOP
    DBMS_OUTPUT.PUT_LINE('Umowa ' || r.umowa_id || ' | ' || r.imie || ' ' || r.nazwisko || ' | ' || r.nazwa_kursu || ' | ' || r.cena || ' zł | ' || r.miasto);
  END LOOP;
END;
/


